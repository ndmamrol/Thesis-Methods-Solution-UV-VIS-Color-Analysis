    # collect files
    files = []
    for ext in ("*.csv", "*.txt", "*.dat"):
        files.extend(glob.glob(os.path.join(DATA_FOLDER, ext)))
    if not files:
        raise FileNotFoundError(f"No spectrum files found in {DATA_FOLDER}")

    # load spectra to grid
    spectra_raw = {}
    for fp in files:
        if os.path.basename(fp).lower() == BASELINE_FILENAME.lower():
            continue
        adv, label_name = adv_id_and_label_from_filename(fp)
        if not adv:
            continue
        wl, y = read_two_col_spectrum(fp)
        #wl, y = clip_and_normalize(wl, y, WL_MIN, WL_MAX)
        y_grid = interp_to_grid(wl, y, grid_nm)
        spectra_raw[adv] = y_grid

    if "ADV0" not in spectra_raw:
        raise FileNotFoundError("ADV0 not found (filename must contain ADV0).")

    out_dir = os.path.join(DATA_FOLDER, "delta_as_absorbance_color")
    plot_dir = os.path.join(out_dir, "plots")
    os.makedirs(out_dir, exist_ok=True)
    os.makedirs(plot_dir, exist_ok=True)

    adv0_raw = spectra_raw["ADV0"]
    adv0_bl = subtract_baseline(adv0_raw, baseline)

    candidates = sorted([k for k in spectra_raw.keys() if k != "ADV0"],
                        key=lambda s: int(re.sub(r"\D", "", s) or "0"))


    summary_path = os.path.join(out_dir, "summary_absorbance_color.csv")
    header_written = False

    with open(summary_path, "w", encoding="utf-8") as fsum:
        for adv in candidates:
            label_name = ADV_LABEL_MAP.get(adv, adv)
            sample_raw = spectra_raw[adv]
            sample_bl = subtract_baseline(sample_raw, baseline)

            # delta_raw = ADV0 - dyed
            # ---- convert to percent for plotting ----
            adv0_pct   = adv0_bl /100
            sample_pct = sample_bl /100.0
            
            # ---- delta in percent ----
            #delta_pct = adv0_pct - sample_pct   # can be negative
            
            # ---- absorbance from reflectance ratio (percent cancels) ----
            A = absorbance_from_reflectance_percent(adv0_pct, sample_pct)
            
            # ---- transmittance factor for color ----
            T = transmittance_from_absorbance(A, K=K_ABSORBANCE)
            
            # for color integration, T must be a spectral factor in [0,1]
            #T_clip = np.clip(T, 0.0, 1.0)
            
            rgb_sample, _ = color_from_factor(np.clip(sample_bl, 0, 1), xbar, ybar, zbar, illum, GRID_STEP_NM)
            rgb_T, XYZ_d65 = color_from_factor(T, xbar, ybar, zbar, illum, GRID_STEP_NM)
            xy = xy_from_xyz(XYZ_d65)



            # Summary row
            row = {
                "sample": adv,
                "baseline_used": os.path.basename(baseline_fp) if baseline_fp else "",
                "K_absorbance": K_ABSORBANCE,
                "xy_x": xy[0],
                "xy_y": xy[1],
                "sRGB_R": float(rgb_T[0]),
                "sRGB_G": float(rgb_T[1]),
                "sRGB_B": float(rgb_T[2]),
            }

            if not header_written:
                fsum.write(",".join(row.keys()) + "\n")
                header_written = True
            fsum.write(",".join(str(row[k]) for k in row.keys()) + "\n")
            rgb_sample, _ = color_from_factor(sample_bl, xbar, ybar, zbar, illum, GRID_STEP_NM)
            
            plot_absorbance_pipeline_percent(
                grid_nm=grid_nm,
                sample_pct=sample_pct,
                adv0_pct=adv0_pct,
                #delta_pct=delta_pct,
                A=A,
                T=T,
                rgb_sample=rgb_sample,
                rgb_T=rgb_T,
                label_name=label_name,
            )
            print(f"{adv}: sRGB={tuple(np.round(rgb_T, 3))}  xy=({xy[0]:.3f},{xy[1]:.3f})")
    print(f"\nDone. Outputs in: {out_dir}")
