def save_figure_pdf(fig, filename, outdir=PDF_OUTDIR, dpi=300):
    os.makedirs(outdir, exist_ok=True)
    outpath = os.path.join(outdir, f"{filename}.pdf")
    fig.savefig(outpath, dpi=dpi, bbox_inches="tight", facecolor="white")


def absorbance_from_reflectance_percent(R_white_pct, R_dyed_pct):
    """
    A = log10(R_white / R_dyed) using reflectance in percent.
    Returns absorbance (unitless). Can be negative if dyed > white at some λ.
    """
    Rw = np.asarray(R_white_pct, float)
    Rd = np.asarray(R_dyed_pct, float)
    Rw = np.clip(Rw, EPS, None)
    Rd = np.clip(Rd, EPS, None)
    return np.log10(Rw / Rd)

def transmittance_from_absorbance(A, K=1.0):
    """
    T = 10^(-K*A)
    Returns factor in (0, inf). For color integration we clip to [0,1].
    """
    A = np.asarray(A, float)
    T = 10 ** (-K * A)
    return T

