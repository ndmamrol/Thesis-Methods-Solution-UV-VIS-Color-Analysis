def plot_all_absorbance_4x4(grid_nm, A_list, labels, rgb_list,
                            outpath=None, figsize=(7, 7),
                            nrows=4, ncols=4, lw=1.6, show=True):
    """
    Plots each absorbance spectrum in its own subplot (4x4 by default),
    with the line colored by the corresponding rgb_T.
    """
    fig, axes = plt.subplots(nrows, ncols, figsize=figsize, sharex=True, sharey=False)
    axes = np.array(axes).reshape(nrows, ncols)

    for i in range(nrows * ncols):
        r, c = divmod(i, ncols)
        ax = axes[r, c]

        if i < len(A_list):
            A = np.asarray(A_list[i], float)
            rgb = tuple(np.clip(np.asarray(rgb_list[i], float), 0.0, 1.0))
            ax.plot(grid_nm, A, color='black', linewidth=2.6)
            ax.plot(grid_nm, A, color=rgb, linewidth=lw)
            # subplot label (a), b), c)...) in top-right corner
            letters = list(string.ascii_lowercase)
            ax.set_xlabel("Wavelength (nm)")
            ax.set_ylabel("Absorbance")
            ax.text(
                0.95, 0.95,
                f"{letters[i]})",
                transform=ax.transAxes,
                ha="right",
                va="top",
                fontsize=10
            )
            ax.set_ylim(-0.05,0.85)
        else:
            ax.axis("off")
            continue

    plt.tight_layout()
    save_figure_pdf(fig, f"4_4_uvviv_absorbance")
    plt.show()
    
   

    
