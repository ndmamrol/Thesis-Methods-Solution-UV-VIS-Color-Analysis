def main():
    grid_nm = np.arange(WL_MIN, WL_MAX + GRID_STEP_NM, GRID_STEP_NM)

    # CMFs + illuminant
    xbar, ybar, zbar = load_cmf_to_grid(CMF_PATH, grid_nm)
    illum = load_illuminant_to_grid(ILLUMINANT_MODE, grid_nm)

