# COLOR: CMFs + illuminant + XYZ -> Bradford -> sRGB
# ============================================================
def load_cmf_to_grid(cmf_path: str, grid_nm: np.ndarray):
    arr = None
    for delim in [None, ",", "\t", ";"]:
        try:
            arr = np.genfromtxt(cmf_path, delimiter=delim, comments="#")
            if arr.ndim == 2 and arr.shape[1] >= 4:
                break
        except Exception:
            continue
    if arr is None or arr.ndim != 2 or arr.shape[1] < 4:
        raise ValueError(f"CMF file not understood: {cmf_path}")

    wl = arr[:, 0].astype(float)
    xbar = arr[:, 1].astype(float)
    ybar = arr[:, 2].astype(float)
    zbar = arr[:, 3].astype(float)

    m = np.isfinite(wl) & np.isfinite(xbar) & np.isfinite(ybar) & np.isfinite(zbar)
    wl, xbar, ybar, zbar = wl[m], xbar[m], ybar[m], zbar[m]
    idx = np.argsort(wl)
    wl, xbar, ybar, zbar = wl[idx], xbar[idx], ybar[idx], zbar[idx]

    xg = np.interp(grid_nm, wl, xbar, left=0.0, right=0.0)
    yg = np.interp(grid_nm, wl, ybar, left=0.0, right=0.0)
    zg = np.interp(grid_nm, wl, zbar, left=0.0, right=0.0)
    return xg, yg, zg

def load_illuminant_to_grid(mode: str, grid_nm: np.ndarray):
    if mode.upper() == "E":
        return np.ones_like(grid_nm, dtype=float)
    if mode.upper() == "FILE":
        if not ILLUMINANT_FILE or not os.path.exists(ILLUMINANT_FILE):
            raise FileNotFoundError("ILLUMINANT_MODE='FILE' but ILLUMINANT_FILE path is missing/invalid.")
        wl, p = read_two_col_spectrum(ILLUMINANT_FILE)
        p = np.maximum(p, 0.0)
        pg = np.interp(grid_nm, wl, p, left=p[0], right=p[-1])
        return pg
    raise ValueError("ILLUMINANT_MODE must be 'E' or 'FILE'.")

def xyz_from_spectral_factor(F, xbar, ybar, zbar, illum, grid_step_nm):
    """
    F is a spectral factor in [0,1] (reflectance OR transmittance).
    For absorbance-derived color, we will pass F = T(λ).
    """
    #F = np.clip(np.asarray(F, float), 0.0, 1.0)
    F = np.asarray(F, float)
    S = np.clip(np.asarray(illum, float), 0.0, np.inf)

    denom = np.sum(S * ybar) * grid_step_nm
    if denom <= EPS:
        return np.array([np.nan, np.nan, np.nan], float)

    k = 1.0 / denom  # ensures perfect diffuser/transmitter gives Y=1
    X = k * np.sum(F * S * xbar) * grid_step_nm
    Y = k * np.sum(F * S * ybar) * grid_step_nm
    Z = k * np.sum(F * S * zbar) * grid_step_nm
    return np.array([X, Y, Z], float)

def xyz_to_srgb_D65(XYZ):
    """
    XYZ referenced to D65 -> sRGB (clipped).
    """
    X, Y, Z = np.asarray(XYZ, float)
    M = np.array([
        [ 3.2406, -1.5372, -0.4986],
        [-0.9689,  1.8758,  0.0415],
        [ 0.0557, -0.2040,  1.0570],
    ], float)
    rgb_lin = M @ np.array([X, Y, Z], float)

    def gamma(u):
        u = np.asarray(u, float)
        return np.where(u <= 0.0031308, 12.92*u,
                        1.055*np.power(np.maximum(u, 0), 1/2.4) - 0.055)

    return np.clip(gamma(rgb_lin), 0.0, 1.0)

def white_xyz_from_illuminant(xbar, ybar, zbar, illum, grid_step_nm):
    """
    Whitepoint under your illuminant for factor=1, normalized so Y=1.
    """
    S = np.clip(np.asarray(illum, float), 0.0, np.inf)
    X = np.sum(S * xbar) * grid_step_nm
    Y = np.sum(S * ybar) * grid_step_nm
    Z = np.sum(S * zbar) * grid_step_nm
    if Y <= EPS:
        return np.array([np.nan, np.nan, np.nan], float)
    return np.array([X / Y, 1.0, Z / Y], float)

def bradford_adapt_XYZ(XYZ, src_white_XYZ, dst_white_XYZ):
    """
    Adapt XYZ from src illuminant white to dst white (Bradford).
    """
    XYZ = np.asarray(XYZ, float)
    src = np.asarray(src_white_XYZ, float)
    dst = np.asarray(dst_white_XYZ, float)

    M = np.array([[ 0.8951,  0.2664, -0.1614],
                  [-0.7502,  1.7135,  0.0367],
                  [ 0.0389, -0.0685,  1.0296]], float)
    Minv = np.linalg.inv(M)

    src_LMS = M @ src
    dst_LMS = M @ dst
    D = np.diag(dst_LMS / np.clip(src_LMS, EPS, np.inf))

    return Minv @ (D @ (M @ XYZ))

def color_from_factor(F, xbar, ybar, zbar, illum, grid_step_nm):
    """
    Computes sRGB using chromatic adaptation to D65 if illuminant != D65.
    """
    D65_WHITE = np.array([0.95047, 1.00000, 1.08883], float)

    XYZ_src = xyz_from_spectral_factor(F, xbar, ybar, zbar, illum, grid_step_nm)
    src_white = white_xyz_from_illuminant(xbar, ybar, zbar, illum, grid_step_nm)

    XYZ_d65 = bradford_adapt_XYZ(XYZ_src, src_white, D65_WHITE)
    rgb = xyz_to_srgb_D65(XYZ_d65)
    return rgb, XYZ_d65

def xy_from_xyz(xyz: np.ndarray):
    X, Y, Z = xyz
    s = X + Y + Z
    if s <= EPS:
        return (np.nan, np.nan)
    return (float(X/s), float(Y/s))

