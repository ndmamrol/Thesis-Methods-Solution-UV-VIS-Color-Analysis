def adv_id_and_label_from_filename(path: str):
    """
    Returns (adv_id, label)
    Example: "sample_ADV16.csv" -> ("ADV16", "Disperse Red 1")
    """
    m = re.search(r"(ADV\s*0|ADV\s*\d+)", os.path.basename(path), re.IGNORECASE)
    if not m:
        return None, None

    adv_id = m.group(1).replace(" ", "").upper()
    label = ADV_LABEL_MAP.get(adv_id, adv_id)  # fallback to ADV#

    return adv_id, label

def read_two_col_spectrum(path: str):
    for delim in [",", "\t", ";", None]:
        try:
            arr = np.genfromtxt(path, delimiter=delim, comments="#")
            if arr.ndim != 2 or arr.shape[1] < 2:
                continue
            wl = arr[:, 0].astype(float)
            y  = arr[:, 1].astype(float)
            m = np.isfinite(wl) & np.isfinite(y)
            wl, y = wl[m], y[m]
            idx = np.argsort(wl)
            return wl[idx], y[idx]
        except Exception:
            continue
    raise ValueError(f"Could not read spectrum: {path}")

def clip_and_normalize(wl, y, wl_min, wl_max):
    m = (wl >= wl_min) & (wl <= wl_max) & np.isfinite(y)
    wl2, y2 = wl[m], y[m]
    if wl2.size < 5:
        raise ValueError("Too few points after clipping.")
    if AUTO_NORMALIZE_PERCENT and np.nanmax(y2) > 1.5:
        y2 = y2 / 100.0
    return wl2, y2

def interp_to_grid(wl, y, grid_nm):
    return np.interp(grid_nm, wl, y, left=y[0], right=y[-1])

def load_baseline(grid_nm):
    if not USE_BASELINE:
        return None, None
    fp = os.path.join(DATA_FOLDER, BASELINE_FILENAME)
    if not os.path.exists(fp):
        print(f"NOTE: baseline not found ({fp}). Skipping baseline subtraction.")
        return None, None
    wl, y = read_two_col_spectrum(fp)
    #wl, y = clip_and_normalize(wl, y, WL_MIN, WL_MAX)
    base = interp_to_grid(wl, y, grid_nm)
    return fp, base

def subtract_baseline(y, baseline_grid):
    if baseline_grid is None:
        return y
    return np.maximum(y - baseline_grid, 0.0)

# ============================================================
# Absorbance normalization + mapping to transmittance factor
# ============================================================
def normalize_to_0_1(a):
    a = np.asarray(a, float)
    a = np.where(np.isfinite(a), a, 0.0)
    a_min = np.min(a)
    a_max = np.max(a)
    rng = a_max - a_min
    if rng < EPS:
        return np.zeros_like(a)
    return (a - a_min) / rng

def absorbance_norm_to_transmittance(A_norm, k=2.0):
    A_norm = np.clip(np.asarray(A_norm, float), 0.0, 1.0)
    # Beer-Lambert-ish mapping (shape only)
    T = 10.0 ** (-k * A_norm)
    return np.clip(T, 0.0, 1.0)

