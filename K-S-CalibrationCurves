                s=45,
                facecolor=this_color,
                edgecolor="black",
                linewidth=0.8,
                zorder=3
            )

        # fit line
        if len(sub_std) >= 2 and np.isfinite(sub_fit["slope"]):
            xfit = np.linspace(0.5, 4.0, 100)
            yfit = sub_fit["slope"] * xfit + sub_fit["intercept"]
            ax.plot(xfit, yfit, "-", color="black", linewidth=1.0, zorder=2)

        # sample point
        if len(sub_sam) > 0:
            sample_ks = sub_sam["KS"].iloc[0]
            est_conc = sub_est["estimated_concentration_from_fit"]

            if PLOT_SAMPLE_ESTIMATED_CONC and np.isfinite(est_conc):
                ax.scatter(
                    [est_conc],
                    [sample_ks],
                    s=55,
                    marker="s",
                    facecolor=this_color,
                    edgecolor="black",
                    linewidth=0.8,
                    zorder=4
                )

            ax.text(
                0.98, 0.05,
                f"sample K/S={sample_ks:.2f}",
                transform=ax.transAxes,
                ha="right", va="bottom",
                fontsize=10,
                bbox=dict(facecolor="white", edgecolor="black", alpha=0.8)
            )

        # panel label only, no ADV title
        ax.text(
            0.03, 0.97,
            f"({panel_labels[i]})",
            transform=ax.transAxes,
            ha="left", va="top",
            fontsize=10,
            
        )

        ax.set_xlim(0, 4.5)
        ax.set_xticks([0, 1, 2, 3, 4])
        ax.set_xlabel("Conc.")
        ax.set_ylabel("K/S")
        ax.tick_params(labelsize=8)

        if len(sub_std) == 0:
            ax.text(
                0.5, 0.5, "no standards",
                ha="center", va="center",
                transform=ax.transAxes
            )

    for j in range(len(subset), 16):
        axes[j].axis("off")

    plt.tight_layout()
    plt.savefig(OUTDIR / f"ADV_calibration_grid_page_{page + 1}.png", bbox_inches="tight")
    plt.close()
