def find_csv_files(root: Path):
    return sorted(root.glob("*.csv"))

def parse_adv_filename(path: Path):
    stem = path.stem.lower().strip()

    m_sample = re.match(r"adv\s*([0-9]{1,2})_sample\b", stem)
    if m_sample:
        adv = int(m_sample.group(1))
        return {"type": "adv", "adv": adv, "kind": "sample", "conc": None}

    m_num = re.match(r"adv\s*([0-9]{1,2})_([0-9]*\.?[0-9]+)\b", stem)
    if m_num:
        adv = int(m_num.group(1))
        conc = float(m_num.group(2))
        return {"type": "adv", "adv": adv, "kind": "standard", "conc": conc}

    return None

def parse_fws_filename(path: Path):
    stem = path.stem.lower().strip()
    m = re.match(r"fws[-_ ]?([0-9]{1,3})\b", stem)
    if m:
        pct = int(m.group(1))
        return {"type": "fws", "percent": pct}
    return None

def is_baseline_file(path: Path):
    stem = path.stem.lower()
    return (
        "100% absorbance baseline" in stem
        or "0 absorbance baseline" in stem
        or "100 absorbance baseline" in stem
        or "0% absorbance baseline" in stem
    )

def detect_xy_columns(df: pd.DataFrame):
    numeric_cols = []
    for c in df.columns:
        series = pd.to_numeric(df[c], errors="coerce")
        frac_numeric = series.notna().mean()
        if frac_numeric > 0.5:
            numeric_cols.append(c)

    if len(numeric_cols) >= 2:
        return numeric_cols[0], numeric_cols[1]
    return None, None

def read_spectrum_csv(path: Path):
    trials = [
        dict(header=0),
        dict(header=None),
        dict(skiprows=1, header=None),
        dict(skiprows=2, header=None),
        dict(skiprows=3, header=None),
        dict(skiprows=4, header=None),
        dict(skiprows=5, header=None),
        dict(skiprows=10, header=None),
    ]

    best_df = None

    for kwargs in trials:
        try:
            df = pd.read_csv(path, **kwargs)
        except Exception:
            continue

        if kwargs.get("header", None) is None:
            df = df.copy()
            df.columns = [f"col_{i}" for i in range(df.shape[1])]

        xcol, ycol = detect_xy_columns(df)
        if xcol is None or ycol is None:
            continue

        out = pd.DataFrame({
            "wavelength": pd.to_numeric(df[xcol], errors="coerce"),
            "value": pd.to_numeric(df[ycol], errors="coerce")
        }).dropna()

        if len(out) < 10:
            continue

        out = out.sort_values("wavelength").drop_duplicates("wavelength")
        if out["wavelength"].between(200, 2500).sum() > 10:
            best_df = out.reset_index(drop=True)
            break

    if best_df is None:
        raise ValueError(f"Could not parse spectrum from {path.name}")

    return best_df

def interp_to_reference(x_ref, x, y):
    return np.interp(x_ref, x, y)

def nearest_value_at(x, y, target):
    idx = np.argmin(np.abs(np.asarray(x) - target))
    return float(np.asarray(y)[idx]), float(np.asarray(x)[idx])

def ks_from_reflectance(R):
    R = np.asarray(R, dtype=float)
    R = np.clip(R, 1e-8, None)
    return ((1 - R) ** 2) / (2 * R)

def format_conc_label(c):
    if c is None:
        return "sample"
    if float(c).is_integer():
        return str(int(c))
    return str(c)

